{
  "name": "hyper-react",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "react-router dev",
    "dev:backend": "cd backend && npx tsx index.ts",
    "refresh": "npx rimraf data/database.sqlite && npm run migration:run && echo '✅ Database reset and migrated successfully!'",
    "setup": "npm install && npm run migration:run && echo '✅ Setup complete! Run npm run dev to start the project.'",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "migration:run": "tsx backend/database/migration-runner.ts",
    "migration:revert": "tsx backend/database/migration-runner.ts revert",
    "test": "vitest run",
    "test:frontend": "vitest run app/tests/",
    "test:backend": "vitest run backend/tests/",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@vitest/coverage-v8": "^4.1.4",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "colorette": "^2.0.20",
    "dotenv": "^17.4.1",
    "hyper-express": "^6.17.3",
    "isbot": "^5.1.36",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.28.16",
    "kysely-generic-sqlite": "^1.2.1",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.14.0",
    "resend": "^6.10.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "rimraf": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
